<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/journal_editor_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/journal_editor_header"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="@color/surface_soft"
        android:paddingTop="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_journal_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_journal_prev_day"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/previous"
            android:src="@drawable/ic_arrow_left"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_journal_edit_date"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_journal_edit_date"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:ellipsize="end"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxWidth="190dp"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_journal_next_day"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/next"
            android:src="@drawable/ic_arrow_right"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_journal_edit_date"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_journal_delete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_delete"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/journal_editor_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/journal_format_toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/journal_editor_header">

        <ImageView
            android:id="@+id/journal_pattern_background"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/journal_editor_pattern"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/journal_page"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="32dp"
            android:background="@drawable/bg_journal_editor_page"
            android:paddingStart="8dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_min="420dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="388dp">

            <LinearLayout
                android:id="@+id/journal_mood_row"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btn_journal_weather_selection"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/journal_tool_mood"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/journal_emo_nang" />

                <ImageButton
                    android:id="@+id/btn_journal_day_selection"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/journal_tool_mood"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/journal_emo_vui" />

                <ImageButton
                    android:id="@+id/btn_journal_body_selection"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/journal_tool_mood"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/journal_emo_sang_khoai" />
            </LinearLayout>

            <EditText
                android:id="@+id/edit_journal_caption"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:background="@color/surface"
                android:gravity="center_vertical|start"
                android:hint="@string/journal_caption_hint"
                android:includeFontPadding="false"
                android:inputType="textCapSentences"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/journal_placeholder"
                android:textCursorDrawable="@drawable/cursor_primary"
                android:textSize="25sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/journal_mood_row" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/journal_photo_row"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/edit_journal_caption">

                <FrameLayout
                    android:id="@+id/journal_photo_slot_1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_journal_image_slot"
                    android:clickable="true"
                    android:clipToOutline="true"
                    android:contentDescription="@string/journal_photo_slot"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/journal_photo_slot_2"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/img_journal_photo_1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/img_journal_photo_add_1"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_journal_add_photo" />

                    <ImageButton
                        android:id="@+id/btn_remove_journal_photo_1"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/journal_photo_remove"
                        android:src="@drawable/ic_journal_remove_image"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/journal_photo_slot_2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_journal_image_slot"
                    android:clickable="true"
                    android:clipToOutline="true"
                    android:contentDescription="@string/journal_photo_slot"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/journal_photo_slot_3"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/journal_photo_slot_1"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/img_journal_photo_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/img_journal_photo_add_2"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_journal_add_photo"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btn_remove_journal_photo_2"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/journal_photo_remove"
                        android:src="@drawable/ic_journal_remove_image"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/journal_photo_slot_3"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_journal_image_slot"
                    android:clickable="true"
                    android:clipToOutline="true"
                    android:contentDescription="@string/journal_photo_slot"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/journal_photo_slot_2"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/img_journal_photo_3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/img_journal_photo_add_3"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_journal_add_photo"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btn_remove_journal_photo_3"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/journal_photo_remove"
                        android:src="@drawable/ic_journal_remove_image"
                        android:visibility="gone" />
                </FrameLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <EditText
                android:id="@+id/edit_journal_content"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:background="@color/surface"
                android:gravity="top|start"
                android:hint="@string/journal_content_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:lineSpacingExtra="3dp"
                android:minHeight="190dp"
                android:overScrollMode="never"
                android:paddingStart="0dp"
                android:paddingTop="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="16dp"
                android:scrollbars="vertical"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/journal_placeholder"
                android:textCursorDrawable="@drawable/cursor_primary"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/journal_photo_row" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <HorizontalScrollView
        android:id="@+id/journal_format_toolbar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/surface_soft"
        android:fillViewport="false"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/journal_bottom_toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/btn_journal_align_left"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/journal_format_align_left"
                android:focusable="false"
                android:padding="8dp"
                android:src="@drawable/ic_format_align_left" />

            <ImageButton
                android:id="@+id/btn_journal_align_center"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/journal_format_align_center"
                android:focusable="false"
                android:padding="8dp"
                android:src="@drawable/ic_format_align_center" />

            <ImageButton
                android:id="@+id/btn_journal_align_right"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/journal_format_align_right"
                android:focusable="false"
                android:padding="8dp"
                android:src="@drawable/ic_format_align_right" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@color/line" />

            <ImageButton
                android:id="@+id/btn_journal_bold"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/journal_format_bold"
                android:focusable="false"
                android:padding="8dp"
                android:src="@drawable/ic_format_bold" />

            <ImageButton
                android:id="@+id/btn_journal_italic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/journal_format_italic"
                android:focusable="false"
                android:padding="8dp"
                android:src="@drawable/ic_format_italic" />

            <ImageButton
                android:id="@+id/btn_journal_underline"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/journal_format_underline"
                android:focusable="false"
                android:padding="8dp"
                android:src="@drawable/ic_format_underline" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@color/line" />

            <ImageButton
                android:id="@+id/btn_journal_text_decrease"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/journal_format_text_decrease"
                android:focusable="false"
                android:padding="8dp"
                android:src="@drawable/ic_format_text_decrease" />

            <ImageButton
                android:id="@+id/btn_journal_text_increase"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/journal_format_text_increase"
                android:focusable="false"
                android:padding="8dp"
                android:src="@drawable/ic_format_text_increase" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/journal_bottom_toolbar"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:background="@color/surface_soft"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btn_journal_camera"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/journal_tool_camera"
            android:padding="4dp"
            android:src="@drawable/ic_journal_camera"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_journal_content_tool"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/journal_tool_content"
            android:padding="4dp"
            android:src="@drawable/ic_journal_lines"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_journal_camera"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_journal_mood"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/journal_tool_mood"
            android:padding="4dp"
            android:src="@drawable/ic_journal_mood"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_journal_content_tool"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_journal_layout"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/journal_tool_layout"
            android:padding="4dp"
            android:src="@drawable/ic_journal_layout"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_journal_mood"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_journal_save"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/save"
            android:padding="2dp"
            android:src="@drawable/ic_journal_tick"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
