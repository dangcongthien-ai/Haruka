<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="22dp"
    android:paddingEnd="10dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layout_habit_header_actions"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_habit_report"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_icon_button_ripple"
                android:contentDescription="@string/habit_report_title"
                android:padding="7dp"
                android:src="@drawable/ic_journal_chart" />

            <ImageButton
                android:id="@+id/btn_habit_sort"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_icon_button_ripple"
                android:contentDescription="@string/habit_sort"
                android:padding="7dp"
                android:src="@drawable/ic_journal_sort" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <TextView
            android:id="@+id/btn_habit_today"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="start|center_vertical"
            android:background="@drawable/bg_surface_card_soft_ripple"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:minWidth="68dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/today"
            android:textColor="@color/brand_orange_dark"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/habit_date_row"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_habit_prev_day"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_icon_button_ripple"
                android:contentDescription="@string/previous"
                android:padding="9dp"
                android:src="@drawable/ic_arrow_left" />

            <TextView
                android:id="@+id/tv_habit_date"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:minWidth="126dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <ImageButton
                android:id="@+id/btn_habit_next_day"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_icon_button_ripple"
                android:contentDescription="@string/next"
                android:padding="9dp"
                android:src="@drawable/ic_arrow_right" />
        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/habit_filter_row"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_habit_filter_all"
            style="@style/Haruka.SegmentButton"
            android:text="@string/all" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_habit_filter_pending"
            style="@style/Haruka.SegmentButton"
            android:text="@string/todo_filter_pending"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_habit_filter_done"
            style="@style/Haruka.SegmentButton"
            android:text="@string/todo_filter_done"
            android:textSize="13sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_habits"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="10dp" />

        <LinearLayout
            android:id="@+id/layout_habit_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_habit_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/habit_empty"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_habit_empty_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/habit_empty_hint"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_habit_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_habit_summary_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/habit_today_progress"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_habit_summary_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/habit_summary_progress_track"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_habit_progress_track">

            <View
                android:id="@+id/habit_summary_progress_fill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_habit_progress_fill" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
