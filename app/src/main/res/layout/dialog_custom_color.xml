<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="312dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_confirmation"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/custom_color"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:id="@+id/view_custom_color_preview"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp" />

    <EditText
        android:id="@+id/edit_custom_color_hex"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_orange_outline"
        android:gravity="center_vertical"
        android:hint="@string/custom_color_hint"
        android:inputType="textCapCharacters"
        android:maxLines="1"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textCursorDrawable="@drawable/cursor_primary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_custom_color_cancel"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/surface"
            app:cornerRadius="21dp"
            app:strokeColor="@color/line"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_custom_color_apply"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="@string/apply"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/brand_orange"
            app:cornerRadius="21dp" />
    </LinearLayout>
</LinearLayout>
