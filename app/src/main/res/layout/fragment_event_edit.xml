<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/event_edit_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/event_edit_header"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:elevation="3dp"
        android:translationZ="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cancel"
            android:src="@drawable/ic_back" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_event"
            android:layout_width="88dp"
            android:layout_height="40dp"
            android:text="@string/save"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="@color/brand_orange"
            app:cornerRadius="20dp"
            app:rippleColor="@color/ripple_orange_pressed" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/event_edit_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/event_edit_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/surface_soft" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/title_row"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/brand_orange" />

                    <EditText
                        android:id="@+id/edit_event_title"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:hint="@string/title_hint"
                        android:inputType="textCapSentences"
                        android:padding="0dp"
                        android:textColor="@color/text_primary"
                        android:textColorHighlight="@color/brand_orange_highlight"
                        android:textColorHint="@color/brand_orange_hint"
                        android:textCursorDrawable="@drawable/cursor_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_habit_color" />

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="@string/color"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="0dp"
                        android:layout_weight="1"
                        android:fillViewport="true"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/color_palette"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp" />
                    </HorizontalScrollView>

                    <LinearLayout
                        android:id="@+id/custom_color_trigger"
                        android:layout_width="88dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_surface_card_soft"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <View
                            android:id="@+id/view_custom_color_trigger_preview"
                            android:layout_width="18dp"
                            android:layout_height="18dp" />

                        <TextView
                            android:id="@+id/tv_custom_color_trigger_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/custom"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />

                        <ImageView
                            android:id="@+id/iv_custom_color_trigger_check"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check"
                            android:visibility="gone"
                            app:tint="@color/brand_orange_dark" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/type_segment"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_event_type"
                        style="@style/Caliary.SegmentButton"
                        android:text="@string/event"
                        app:icon="@drawable/ic_calendar"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconSize="16dp"
                        app:iconTint="@color/brand_orange" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_todo_type"
                        style="@style/Caliary.SegmentButton"
                        android:text="@string/todo"
                        app:icon="@drawable/ic_todo"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconSize="15dp"
                        app:iconTint="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/surface_soft" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="@color/brand_orange" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/all_day_event"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_all_day"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:scaleX="0.74"
                        android:scaleY="0.74"
                        app:thumbTint="@color/switch_thumb"
                        app:trackTint="@color/switch_track" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/line" />

                <LinearLayout
                    android:id="@+id/start_row"
                    style="@style/Caliary.FormRow">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_habit_start" />

                    <TextView
                        android:layout_width="88dp"
                        android:layout_height="wrap_content"
                        android:text="@string/start"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_start_date"
                        style="@style/Caliary.FormValue" />

                    <FrameLayout
                        android:id="@+id/start_time_container"
                        android:layout_width="72dp"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/tv_start_time"
                            style="@style/Caliary.FormTime" />
                    </FrameLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/line" />

                <LinearLayout
                    android:id="@+id/end_row"
                    style="@style/Caliary.FormRow">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_habit_end" />

                    <TextView
                        android:layout_width="88dp"
                        android:layout_height="wrap_content"
                        android:text="@string/end"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_end_date"
                        style="@style/Caliary.FormValue" />

                    <FrameLayout
                        android:id="@+id/end_time_container"
                        android:layout_width="72dp"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/tv_end_time"
                            style="@style/Caliary.FormTime" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/surface_soft" />

            <LinearLayout
                android:id="@+id/reminder_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/repeat_row"
                    style="@style/Caliary.FormRow">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_habit_repeat" />

                    <TextView
                        android:layout_width="88dp"
                        android:layout_height="wrap_content"
                        android:text="@string/repeat"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_repeat_value"
                        style="@style/Caliary.FormValueMuted" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/text_muted" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/line" />

                <LinearLayout
                    android:id="@+id/reminder_header_row"
                    style="@style/Caliary.FormRow">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_habit_reminder" />

                    <TextView
                        android:layout_width="88dp"
                        android:layout_height="wrap_content"
                        android:text="@string/reminder"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_reminder_value"
                        style="@style/Caliary.FormValueMuted"
                        android:text="@string/none" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/text_muted" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/reminder_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btn_add_reminder"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:text="@string/add_another_reminder"
                    android:textColor="@color/brand_orange"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/surface_soft" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/location_row"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_event_location" />

                    <EditText
                        android:id="@+id/edit_location"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:hint="@string/location"
                        android:inputType="textCapSentences"
                        android:padding="0dp"
                        android:textColor="@color/text_primary"
                        android:textColorHighlight="@color/brand_orange_highlight"
                        android:textColorHint="@color/brand_orange_hint"
                        android:textCursorDrawable="@drawable/cursor_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/line" />

                <LinearLayout
                    android:id="@+id/url_row"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_event_link" />

                    <EditText
                        android:id="@+id/edit_url"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:hint="@string/url"
                        android:inputType="textUri"
                        android:padding="0dp"
                        android:textColor="@color/text_primary"
                        android:textColorHighlight="@color/brand_orange_highlight"
                        android:textColorHint="@color/brand_orange_hint"
                        android:textCursorDrawable="@drawable/cursor_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/line" />

                <LinearLayout
                    android:id="@+id/notes_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginTop="2dp"
                        android:src="@drawable/ic_habit_description" />

                    <EditText
                        android:id="@+id/edit_notes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:gravity="top|start"
                        android:hint="@string/note_hint"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="3"
                        android:padding="0dp"
                        android:scrollbars="none"
                        android:textColor="@color/text_primary"
                        android:textColorHighlight="@color/brand_orange_highlight"
                        android:textColorHint="@color/brand_orange_hint"
                        android:textCursorDrawable="@drawable/cursor_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:id="@+id/event_edit_bottom_background"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/surface_soft" />

            <View
                android:id="@+id/event_edit_keyboard_spacer"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/surface_soft" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
