<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="204dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_soft"
    android:forceDarkAllowed="false"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="14dp"
    android:paddingEnd="18dp"
    android:paddingBottom="10dp"
    tools:targetApi="q">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:gravity="center"
        android:text="@string/choose_year"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <com.example.finalproject.ui.common.WheelPickerView
        android:id="@+id/picker_year"
        android:layout_width="match_parent"
        android:layout_height="126dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_year_cancel"
            style="@style/Haruka.DialogTextAction"
            android:text="@string/cancel" />

        <TextView
            android:id="@+id/btn_year_ok"
            style="@style/Haruka.DialogTextAction"
            android:layout_marginStart="8dp"
            android:text="@string/ok" />
    </LinearLayout>
</LinearLayout>
