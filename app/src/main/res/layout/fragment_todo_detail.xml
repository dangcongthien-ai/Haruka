<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_edit_todo"
            android:layout_width="90dp"
            android:layout_height="32dp"
            android:text="@string/edit"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/brand_orange"
            app:cornerRadius="22dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@color/surface"
                android:gravity="center"
                android:textColor="@color/brand_orange"
                android:textSize="18sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="@color/app_background" />

            <TextView
                android:id="@+id/tv_detail_description"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@color/surface"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:textColor="@color/brand_orange"
                android:textSize="14sp" />

            <LinearLayout
                style="@style/Caliary.FormRow">

                <TextView
                    style="@style/Caliary.FormLabel"
                    android:text="@string/reminder" />

                <TextView
                    android:id="@+id/tv_detail_reminder"
                    style="@style/Caliary.FormValueMuted" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="@color/app_background" />

            <include
                android:id="@+id/priority_matrix"
                layout="@layout/include_priority_matrix" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
