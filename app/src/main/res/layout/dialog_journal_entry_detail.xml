<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/journal_detail_sheet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_journal_detail_sheet"
    android:clipToOutline="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/journal_detail_header"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:background="@color/surface"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/journal_detail_date_row"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_journal_detail_prev"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/previous"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_left" />

            <TextView
                android:id="@+id/tv_journal_detail_date"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxWidth="162dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/btn_journal_detail_next"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_right" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_journal_detail_edit"
            android:layout_width="42dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/edit"
            android:padding="9dp"
            android:src="@drawable/ic_edit"
            android:translationX="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_journal_detail_delete"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_journal_detail_delete"
            android:layout_width="42dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete"
            android:padding="9dp"
            android:src="@drawable/ic_delete"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/journal_detail_body"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/journal_detail_header">

        <ImageView
            android:id="@+id/img_journal_detail_pattern"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/journal_detail_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:paddingStart="31dp"
            android:paddingTop="32dp"
            android:paddingEnd="31dp"
            android:paddingBottom="40dp">

            <LinearLayout
                android:id="@+id/journal_detail_page"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_journal_editor_page"
                android:minHeight="487dp"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:id="@+id/journal_detail_mood_row"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/img_journal_detail_mood_weather"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />

                    <ImageView
                        android:id="@+id/img_journal_detail_mood_day"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="2dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />

                    <ImageView
                        android:id="@+id/img_journal_detail_mood_body"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="2dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_journal_detail_caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="2"
                    android:minHeight="44dp"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp" />

                <LinearLayout
                    android:id="@+id/journal_detail_photo_row"
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/journal_detail_photo_slot_1"
                        android:layout_width="88dp"
                        android:layout_height="100dp">

                        <ImageView
                            android:id="@+id/img_journal_detail_photo_1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_journal_image_photo"
                            android:clipToOutline="true"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/journal_detail_photo_slot_2"
                        android:layout_width="88dp"
                        android:layout_height="100dp"
                        android:layout_marginStart="16dp">

                        <ImageView
                            android:id="@+id/img_journal_detail_photo_2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_journal_image_photo"
                            android:clipToOutline="true"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/journal_detail_photo_slot_3"
                        android:layout_width="88dp"
                        android:layout_height="100dp"
                        android:layout_marginStart="16dp">

                        <ImageView
                            android:id="@+id/img_journal_detail_photo_3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_journal_image_photo"
                            android:clipToOutline="true"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop" />
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_journal_detail_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:includeFontPadding="true"
                    android:lineSpacingExtra="3dp"
                    android:minHeight="220dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
