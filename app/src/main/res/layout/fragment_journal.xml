<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="22dp"
    android:paddingEnd="10dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_journal_chart"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_icon_button_ripple"
                android:contentDescription="@string/journal_review_chart"
                android:padding="7dp"
                android:src="@drawable/ic_journal_chart" />

            <ImageButton
                android:id="@+id/btn_journal_sort"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_icon_button_ripple"
                android:contentDescription="@string/journal_sort"
                android:padding="7dp"
                android:src="@drawable/ic_journal_sort" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <TextView
            android:id="@+id/btn_journal_today"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="start|center_vertical"
            android:background="@drawable/bg_surface_card_soft_ripple"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:minWidth="68dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/today"
            android:textColor="@color/brand_orange_dark"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/journal_month_row"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_journal_prev_day"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_icon_button_ripple"
                android:contentDescription="@string/previous"
                android:padding="9dp"
                android:src="@drawable/ic_arrow_left" />

            <TextView
                android:id="@+id/tv_journal_date"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:minWidth="118dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <ImageButton
                android:id="@+id/btn_journal_next_day"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_icon_button_ripple"
                android:contentDescription="@string/next"
                android:padding="9dp"
                android:src="@drawable/ic_arrow_right" />
        </LinearLayout>

    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/journal_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="14dp" />

        <TextView
            android:id="@+id/tv_journal_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/journal_empty"
            android:textColor="@color/text_muted"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
