<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp">

    <ImageButton
        android:id="@+id/btn_journal_chart"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/journal_review_chart"
        android:padding="7dp"
        android:src="@drawable/ic_journal_chart"
        app:layout_constraintBottom_toBottomOf="@id/journal_month_row"
        app:layout_constraintEnd_toStartOf="@id/btn_journal_sort"
        app:layout_constraintTop_toTopOf="@id/journal_month_row" />

    <ImageButton
        android:id="@+id/btn_journal_sort"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/journal_sort"
        android:padding="7dp"
        android:src="@drawable/ic_journal_sort"
        app:layout_constraintBottom_toBottomOf="@id/journal_month_row"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/journal_month_row" />

    <LinearLayout
        android:id="@+id/journal_month_row"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_journal_prev_day"
            android:layout_width="34dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/previous"
            android:padding="9dp"
            android:src="@drawable/ic_arrow_left" />

        <TextView
            android:id="@+id/tv_journal_date"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:minWidth="118dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <ImageButton
            android:id="@+id/btn_journal_next_day"
            android:layout_width="34dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/next"
            android:padding="9dp"
            android:src="@drawable/ic_arrow_right" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/journal_recycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingTop="8dp"
        android:paddingBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/journal_month_row" />

    <TextView
        android:id="@+id/tv_journal_empty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:text="@string/journal_empty"
        android:textColor="@color/text_muted"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/journal_recycler"
        app:layout_constraintEnd_toEndOf="@id/journal_recycler"
        app:layout_constraintStart_toStartOf="@id/journal_recycler"
        app:layout_constraintTop_toTopOf="@id/journal_recycler" />
</androidx.constraintlayout.widget.ConstraintLayout>
