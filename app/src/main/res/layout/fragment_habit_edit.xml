<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/surface_soft"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <ImageButton
            android:id="@+id/btn_back_habit"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_habit"
            android:layout_width="88dp"
            android:layout_height="40dp"
            android:text="@string/save"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="@color/brand_orange"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/habit_edit_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <EditText
                android:id="@+id/edit_habit_title"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@color/surface"
                android:gravity="center"
                android:hint="@string/title_hint"
                android:inputType="textCapSentences"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/journal_placeholder"
                android:textCursorDrawable="@drawable/cursor_primary"
                android:textSize="24sp"
                android:textStyle="normal" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:minHeight="52dp"
                android:paddingStart="24dp"
                android:paddingTop="10dp"
                android:paddingEnd="24dp"
                android:paddingBottom="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_habit_color" />

                <TextView
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/color"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:fillViewport="true"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layout_habit_colors"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EFE6DE" />

            <LinearLayout
                android:id="@+id/row_habit_category"
                style="@style/Caliary.FormRow">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_habit_category" />

                <TextView
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:text="@string/habit_category_label"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/img_selected_category"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/habit_category_other" />

                    <TextView
                        android:id="@+id/tv_selected_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EFE6DE" />

            <LinearLayout
                android:id="@+id/row_habit_start"
                style="@style/Caliary.FormRow">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_habit_start" />

                <TextView
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:text="@string/start"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_habit_start"
                    style="@style/Caliary.FormValue" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EFE6DE" />

            <LinearLayout
                android:id="@+id/row_habit_end_toggle"
                style="@style/Caliary.FormRow"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_habit_end" />

                <TextView
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:text="@string/end"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:orientation="vertical">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_habit_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:minWidth="0dp"
                        app:thumbTint="@color/habit_switch_thumb"
                        app:trackTint="@color/habit_switch_track" />

                    <LinearLayout
                        android:id="@+id/layout_habit_end_picker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_habit_end"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EFE6DE" />

            <LinearLayout
                android:id="@+id/row_habit_priority"
                style="@style/Caliary.FormRow">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_habit_priority" />

                <TextView
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:text="@string/habit_priority_label"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical|end"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_habit_priority"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="90dp"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EFE6DE" />

            <LinearLayout
                android:id="@+id/row_habit_repeat"
                style="@style/Caliary.FormRow">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_habit_repeat" />

                <TextView
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:text="@string/repeat"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_habit_repeat"
                    style="@style/Caliary.FormValue" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EFE6DE" />

            <LinearLayout
                android:id="@+id/row_habit_reminder"
                style="@style/Caliary.FormRow">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_habit_reminder" />

                <TextView
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reminder"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_habit_reminder"
                    style="@style/Caliary.FormValue" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EFE6DE" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingTop="16dp"
                android:paddingEnd="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_habit_evaluation" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/habit_evaluation_type"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/group_habit_evaluation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:gravity="end"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_habit_boolean"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:buttonTint="@color/brand_orange"
                        android:text="@string/habit_evaluation_boolean"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/radio_habit_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="end"
                        android:buttonTint="@color/brand_orange"
                        android:text="@string/habit_evaluation_number"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_habit_number_fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="86dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:text="@string/habit_target_type"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <AutoCompleteTextView
                        android:id="@+id/input_habit_operator"
                        android:layout_width="140dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_habit_input_box"
                        android:completionThreshold="0"
                        android:dropDownAnchor="@id/input_habit_operator"
                        android:dropDownHorizontalOffset="0dp"
                        android:dropDownVerticalOffset="6dp"
                        android:drawableEnd="@drawable/ic_arrow_down"
                        android:drawablePadding="6dp"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="6dp"
                        android:hint="@string/habit_target_type_hint"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textCursorDrawable="@drawable/cursor_primary"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="86dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:text="@string/habit_target_value"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_habit_target_value"
                        android:layout_width="80dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_habit_input_box"
                        android:gravity="center"
                        android:hint="@string/habit_target_value_hint"
                        android:imeOptions="actionNext"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textCursorDrawable="@drawable/cursor_primary"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="86dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:text="@string/habit_target_unit"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_habit_target_unit"
                        android:layout_width="96dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_habit_input_box"
                        android:gravity="center"
                        android:hint="@string/habit_target_unit_hint"
                        android:imeOptions="actionDone"
                        android:inputType="textCapWords"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textCursorDrawable="@drawable/cursor_primary"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_habit_description_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_habit_description" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/description_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/edit_habit_description"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_habit_description_box"
                    android:gravity="top|start"
                    android:hint="@string/habit_description_hint"
                    android:inputType="textMultiLine|textCapSentences"
                    android:padding="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:textCursorDrawable="@drawable/cursor_primary"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
